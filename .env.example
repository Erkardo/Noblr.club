# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE: Optional — enables realtime shared state sync.
# If unset, app falls back to localStorage-only.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"

# RESEND: required to dispatch member invite emails after Committee approval.
# Server-side only — never expose in the Vite client bundle. Used by /api/send-invite.ts.
# Create an API key at https://resend.com/api-keys, then verify a sending domain
# (or use the default onboarding@resend.dev in test mode — delivers only to the
# Resend account owner's email).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="onboarding@resend.dev"
RESEND_REPLY_TO="committee@noblr.club"

# APP_URL: used to build login links in outgoing invite emails.
# Vercel sets this automatically in production; in local dev, point to http://localhost:3000.
APP_URL="http://localhost:3000"
